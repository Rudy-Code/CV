---
import { technologies } from '@data/index'
import SectionHeader from '@ui/SectionHeader.astro'
---

<section>
	<SectionHeader text="Technologie" variant="side" />

	<div class="mt-3 space-y-4">
		{
			technologies.map(tech => (
				<div class="">
					<h3 class="text-sm font-semibold text-blue-200/70 uppercase">{tech.label}</h3>
					<div class="mt-3 flex flex-wrap gap-2 text-sm">
						{tech.tags.map(tag => (
							<span class="text-text-muted rounded-md bg-blue-900/40 px-3 py-1.5 text-xs">{tag}</span>
						))}
					</div>
				</div>
			))
		}
	</div>
</section>
